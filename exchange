vim.keymap.set('n', '<leader>p', function()
  local file = vim.fn.expand('%')
  local out = vim.fn.expand('%:r') .. '.html'
  -- Pfad zu den Reveal-Assets aus deiner Nix-Config
  local reveal_url = "/etc/profiles/per-user/" .. os.getenv("USER") .. "/share/reveal.js"
  
  -- Pandoc Befehl:
  -- --embed-resources macht die Datei komplett unabhängig (Bilder/JS wandern ins HTML)
  -- --standalone erzeugt ein komplettes Dokument
  local cmd = string.format(
    "pandoc -t revealjs --standalone --embed-resources --resource-path=. " ..
    "-V revealjs-url=%s -o %s %s",
    reveal_url, out, file
  )

  print("Baue Slides...")
  vim.fn.system(cmd)
  vim.cmd('silent !xdg-open ' .. out)
end, { desc = "Build Reveal.js Slides (Offline & Embedded)" })
