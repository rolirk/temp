 pkgs, ... }: {
  home.stateVersion = "25.11";

  home.sessionVariables = {
    EDITOR = "nvim";
  };

  programs.neovim = {
    enable = true;
    defaultEditor = true;
    withRuby = false;
    withPython3 = false;
    initLua = builtins.readFile ./init.lua;
  };

  programs.fish = {
    enable = true;
    shellAliases = {
      rebuild = "sudo nixos-rebuild switch --flake /home/ro/nixos-config#ro-x230";
      nixos-update = "/home/ro/nixos-config/update.sh";
      fix-caps = "sudo systemctl restart interception-tools";
    };
  };
}
