-- ============================================================
-- 5. Tastenmappings (Deine Favoriten)
-- ============================================================
local map = vim.keymap.set

-- jk als ESC
map("i", "jk", "<Esc>")

-- Bewegung auf sichtbaren Zeilen (bei Wrap)
map("n", "j", "gj")
map("n", "k", "gk")

-- Fensternavigation
map("n", "<C-h>", "<C-w>h")
map("n", "<C-j>", "<C-w>j")
map("n", "<C-k>", "<C-w>k")
map("n", "<C-l>", "<C-w>l")

-- Speichern / Schließen
map("n", "<leader>w", ":w<CR>")
map("n", "<leader>q", ":bd<CR>")
map("n", "<leader><space>", ":nohlsearch<CR>")

-- Telescope
map("n", "<leader>ff", "<cmd>Telescope find_files<CR>")
map("n", "<leader>fg", "<cmd>Telescope live_grep<CR>")
map("n", "<leader>fb", "<cmd>Telescope buffers<CR>")

-- RevealJS Build (Absoluter Pfad für Stabilität)
map('n', '<leader>p', function()
    local file = vim.fn.expand('%')
    local out = vim.fn.expand('%:r') .. '.html'
    local cmd = string.format(
        "pandoc -t revealjs -s --embed-resources --resource-path=.:$HOME/reveal.js " ..
        "-V revealjs-url=$HOME/reveal.js -o '%s' '%s' && xdg-open '%s' &",
        out, file, out
    )
    print("Baue Präsentation...")
    os.execute(cmd)
end, { desc = "Build RevealJS" })

-- Fokus-Modus Toggle (Goyo + Pencil)
local fokus_aktiv = false
map("n", "<leader>fo", function()
  if fokus_aktiv then
    vim.cmd("Goyo!")
    vim.cmd("PencilOff")
    vim.opt.scrolloff = 8
    fokus_aktiv = false
  else
    vim.cmd("Goyo")
    vim.cmd("PencilToggle")
    vim.opt.scrolloff = 999
    fokus_aktiv = true
  end
end, { desc = "Fokus-Modus ein/aus" })

-- Goyo/Limelight Auto-Koppelung
vim.api.nvim_create_autocmd("User", {
  pattern = "GoyoEnter",
  callback = function() vim.cmd("Limelight") end,
})
vim.api.nvim_create_autocmd("User", {
  pattern = "GoyoLeave",
  callback = function() vim.cmd("Limelight!") end,
})
