-- Colorscheme
vim.opt.background = "dark"
vim.cmd("colorscheme gruvbox")

-- Goyo + Limelight
vim.api.nvim_create_autocmd("User", {
  pattern = "GoyoEnter",
  command = "Limelight",
})
vim.api.nvim_create_autocmd("User", {
  pattern = "GoyoLeave",
  command = "Limelight!",
})

vim.g.limelight_conceal_ctermfg = "gray"

-- Goyo und Pencil Mappings
map("n", "<leader>go", ":Goyo<CR>")
map("n", "<leader>pe", ":PencilToggle<CR>")
