-- ============================================================
-- 1. Leader-Taste (Muss ganz oben stehen!)
-- ============================================================
vim.g.mapleader = " "

-- ============================================================
-- 2. lazy.nvim Bootstrap
-- ============================================================
local lazypath = vim.fn.stdpath("data") .. "/lazy/lazy.nvim"
if not vim.loop.fs_stat(lazypath) then
  vim.fn.system({
    "git", "clone", "--filter=blob:none",
    "https://github.com/folke/lazy.nvim.git",
    "--branch=stable", lazypath,
  })
end
vim.opt.rtp:prepend(lazypath)

-- ============================================================
-- 3. Plugins
-- ============================================================
require("lazy").setup({
  -- Design
  { "ellisonleao/gruvbox.nvim", priority = 1000, config = function()
      require("gruvbox").setup({ contrast = "hard" })
      vim.cmd("colorscheme gruvbox")
    end },
  { "nvim-lualine/lualine.nvim", config = { options = { theme = "gruvbox" } } },

  -- Schreiben & Fokus
  { "junegunn/goyo.vim" },
  { "junegunn/limelight.vim" },
  { "reedes/vim-pencil" },
  { "vim-pandoc/vim-pandoc" },
  { "vim-pandoc/vim-pandoc-syntax" },
  { "gioele/vim-autoswap" },

  -- Werkzeuge
  { "nvim-telescope/telescope.nvim", dependencies = { "nvim-lua/plenary.nvim" } },
  { "hrsh7th/nvim-cmp", dependencies = { "hrsh7th/cmp-path", "hrsh7th/cmp-buffer", "hrsh7th/cmp-nvim-lsp" },
    config = function()
      local cmp = require("cmp")
      cmp.setup({
        sources = { { name = "nvim_lsp" }, { name = "buffer" }, { name = "path" } },
        mapping = cmp.mapping.preset.insert({
          ["<Tab>"] = cmp.mapping.select_next_item(),
          ["<CR>"] = cmp.mapping.confirm({ select = true }),
        }),
      })
    end },

  -- LSP: LTeX (Grammatik/Rechtschreibung) - Neue Syntax für 0.11+
  { "neovim/nvim-lspconfig", config = function()
      if vim.lsp.config then
        vim.lsp.config("ltex", { settings = { ltex = { language = "de-DE" } } })
        vim.lsp.enable("ltex")
      else
        require('lspconfig').ltex.setup({ settings = { ltex = { language = "de-DE" } } })
      end
    end },
})

