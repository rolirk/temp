-- 1. Leader-Taste definieren (Muss GANZ OBEN stehen)
vim.g.mapleader = " "

-- 2. lazy.nvim Bootstrap
local lazypath = vim.fn.stdpath("data") .. "/lazy/lazy.nvim"
if not vim.loop.fs_stat(lazypath) then
  vim.fn.system({ "git", "clone", "--filter=blob:none", "https://github.com/folke/lazy.nvim.git", "--branch=stable", lazypath })
end
vim.opt.rtp:prepend(lazypath)

-- 3. Plugins laden
require("lazy").setup({
  { "ellisonleao/gruvbox.nvim", priority = 1000, config = function() 
      require("gruvbox").setup({ contrast = "hard" })
      vim.cmd("colorscheme gruvbox") 
    end },
  { "nvim-lualine/lualine.nvim", config = true },
  { "junegunn/goyo.vim" },
  { "reedes/vim-pencil" },
  { "nvim-telescope/telescope.nvim", dependencies = { "nvim-lua/plenary.nvim" } },
  { "neovim/nvim-lspconfig", config = function()
      -- Neue Syntax für nvim 0.11+
      if vim.lsp.config then
        vim.lsp.config("ltex", { settings = { ltex = { language = "de-DE" } } })
        vim.lsp.enable("ltex")
      else
        -- Fallback für ältere Versionen
        require('lspconfig').ltex.setup({ settings = { ltex = { language = "de-DE" } } })
      end
    end },
})

-- 4. Deine Einstellungen
vim.opt.number = true
vim.opt.relativenumber = true
vim.opt.spell = true
vim.opt.spelllang = { "de" }
vim.opt.undofile = true -- Merkt sich Änderungen auch nach Schließen

-- 5. Der RevealJS Shortcut (Der "saubere" Weg)
-- Wir nutzen ein Skript, das prüft ob reveal.js da ist
vim.keymap.set('n', '<leader>p', function()
    local file = vim.fn.expand('%')
    local out = vim.fn.expand('%:r') .. '.html'
    -- Pandoc Befehl: Wir nehmen an, reveal.js liegt in deinem Home-Verzeichnis
    local cmd = string.format(
        "pandoc -t revealjs -s --embed-resources --resource-path=.:$HOME/reveal.js " ..
        "-V revealjs-url=$HOME/reveal.js -o '%s' '%s' && xdg-open '%s' &",
        out, file, out
    )
    print("Baue Präsentation...")
    os.execute(cmd)
end, { desc = "Build RevealJS" })

